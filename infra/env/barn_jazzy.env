# Shell environment for BARN development / benchmarking.
#   source infra/env/barn_jazzy.env
#
# Distrobox can inherit a sourced ROS distribution from the host. Refuse a
# mixed distribution: silently combining Humble and Jazzy causes ABI failures
# that look like planner bugs.
if [[ -n "${ROS_DISTRO:-}" && "${ROS_DISTRO}" != "jazzy" ]]; then
  echo "error: non-Jazzy ROS environment detected (ROS_DISTRO=${ROS_DISTRO})." >&2
  echo "       Enter a clean shell, source /opt/ros/jazzy/setup.bash, then retry." >&2
  return 1 2>/dev/null || exit 1
fi

for _barn_check_var in AMENT_PREFIX_PATH CMAKE_PREFIX_PATH COLCON_PREFIX_PATH PYTHONPATH; do
  IFS=':' read -r -a _barn_check_parts <<< "${!_barn_check_var:-}"
  for _barn_check_path in "${_barn_check_parts[@]}"; do
    if [[ "$_barn_check_path" == /opt/ros/* && "$_barn_check_path" != /opt/ros/jazzy* ]]; then
      echo "error: non-Jazzy ROS path in ${_barn_check_var}: ${_barn_check_path}" >&2
      echo "       Start a clean Jazzy shell instead of layering distributions." >&2
      unset _barn_check_parts _barn_check_path _barn_check_var
      return 1 2>/dev/null || exit 1
    fi
  done
  unset _barn_check_parts _barn_check_path
done
unset _barn_check_var

# Normalize PATH-like variables after validation, removing only empty entries.
_barn_keep_jazzy_paths() {
  local name="$1"
  local value="${!name:-}"
  local part
  local filtered=""

  IFS=':' read -r -a _barn_parts <<< "$value"
  for part in "${_barn_parts[@]}"; do
    [[ -z "$part" ]] && continue
    filtered="${filtered:+${filtered}:}${part}"
  done

  printf -v "$name" '%s' "$filtered"
  export "$name"
  unset _barn_parts
}

for _barn_path_var in \
  AMENT_PREFIX_PATH CMAKE_PREFIX_PATH COLCON_PREFIX_PATH \
  LD_LIBRARY_PATH PATH PKG_CONFIG_PATH PYTHONPATH; do
  _barn_keep_jazzy_paths "$_barn_path_var"
done
unset _barn_path_var
unset -f _barn_keep_jazzy_paths

# ROS 2 middleware / domain isolation so parallel runs don't cross-talk.
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-42}"
export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"

# CPU-only benchmark mode. The BARN physical target has no GPU; always benchmark
# the final navigation inference on CPU. Unset this to train on GPU.
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-}"

# An exported empty filename makes Fast-DDS attempt to parse the wrong input on
# some releases. Leave the variable genuinely absent unless a real file is set.
if [[ -z "${FASTRTPS_DEFAULT_PROFILES_FILE:-}" ]]; then
  unset FASTRTPS_DEFAULT_PROFILES_FILE
fi
