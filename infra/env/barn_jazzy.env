# Shell environment for BARN development / benchmarking.
#   source infra/env/barn_jazzy.env
#
# ROS 2 middleware / domain isolation so parallel runs don't cross-talk.
export ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-42}"
export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"

# CPU-only benchmark mode. The BARN physical target has no GPU; always benchmark
# the final navigation inference on CPU. Unset this to train on GPU.
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-}"

# Convenience: default navigation mode used by the evaluator launch hook.
export BARN_MODE="${BARN_MODE:-classical}"

# Keep Gazebo/Fast-DDS shared memory under the container home.
export FASTRTPS_DEFAULT_PROFILES_FILE="${FASTRTPS_DEFAULT_PROFILES_FILE:-}"
