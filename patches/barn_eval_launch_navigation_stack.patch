diff --git a/jackal_helper/launch/BARN_runner.launch.py b/jackal_helper/launch/BARN_runner.launch.py
--- a/jackal_helper/launch/BARN_runner.launch.py
+++ b/jackal_helper/launch/BARN_runner.launch.py
@@ -1,8 +1,26 @@ def launch_navigation_stack(context, *args, **kwargs):
-    # UPSTREAM: launches the Nav2 baseline navigation stack.
-    # (Exact upstream body varies by revision — this is the hook to replace.)
-    return launch_nav2_baseline(context, *args, **kwargs)
+    # barn-2027-prep integration: replace the Nav2 baseline with our custom
+    # navigation stack. This is the ONLY change made to the evaluator. Gazebo
+    # launch, Jackal spawn, LiDAR remap, collision/goal/timeout monitoring, and
+    # result logging are left untouched.
+    #
+    # The mode is read from the BARN_MODE environment variable (set by
+    # evaluation/scripts/run_single_world.sh), so the same hook drives all three
+    # tracks: classical | e2e_rl | hybrid.
+    import os
+    from ament_index_python.packages import get_package_share_directory
+    from launch.actions import IncludeLaunchDescription
+    from launch.launch_description_sources import PythonLaunchDescriptionSource
+
+    bringup_share = get_package_share_directory('barn_bringup')
+    return [
+        IncludeLaunchDescription(
+            PythonLaunchDescriptionSource(
+                os.path.join(bringup_share, 'launch', 'barn_navigation.launch.py')),
+            launch_arguments={
+                'mode': os.environ.get('BARN_MODE', 'classical'),
+                'use_sim_time': 'true',
+            }.items(),
+        )
+    ]
